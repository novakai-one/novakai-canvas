{
  "schemaVersion": 1,
  "appearance": {
    "density": "comfortable",
    "radius": 6,
    "theme": "dark",
    "accent": "gold"
  },
  "canvas": {
    "showGrid": false,
    "snapToGrid": true,
    "gridSize": 12,
    "showControls": true,
    "showLegend": true
  },
  "nodes": {
    "showKinds": true,
    "showDescriptions": true,
    "showInterfaces": "always",
    "showTypes": true,
    "showPorts": "hover"
  },
  "wires": {
    "showLabels": "always",
    "width": 1.25,
    "dimUnrelated": true
  },
  "panel": {
    "width": 413,
    "defaultTab": "inspect",
    "showEmptyFields": false
  },
  "files": {
    "autoSave": true,
    "saveDelay": 500
  }
}
